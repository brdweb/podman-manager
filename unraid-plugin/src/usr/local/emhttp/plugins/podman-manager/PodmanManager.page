<?php
$docroot = $docroot ?? $_SERVER['DOCUMENT_ROOT'] ?: '/usr/local/emhttp';
$cfg = parse_plugin_cfg('podman-manager');
$apiPort = $cfg['API_PORT'] ?? '18734';
$refreshInterval = $cfg['REFRESH_INTERVAL'] ?? '10000';
?>

<link rel="stylesheet" href="<?autov('/plugins/podman-manager/styles/podman.css')?>">

<div id="podman-header" class="title">
  <span class="left">
    <span id="podman-host-badges"></span>
  </span>
  <span class="right">
    <span id="podman-summary"></span>
    <input type="text" id="podman-filter" placeholder="Filter containers..." class="podman-filter">
  </span>
</div>

<div id="podman-bulk-bar" class="podman-bulk-bar" style="display:none">
  <span id="podman-bulk-count">0 selected</span>
  <button onclick="podmanBulkAction('start')" class="podman-bulk-btn"><i class="fa fa-play"></i> Start</button>
  <button onclick="podmanBulkAction('stop')" class="podman-bulk-btn"><i class="fa fa-stop"></i> Stop</button>
  <button onclick="podmanBulkAction('restart')" class="podman-bulk-btn"><i class="fa fa-refresh"></i> Restart</button>
  <button onclick="podmanClearSelection()" class="podman-bulk-btn podman-bulk-cancel"><i class="fa fa-times"></i> Clear</button>
</div>

<table class="tablesorter shift podman-table" id="podman_list">
  <thead>
    <tr>
      <th class="podman-col-check"><input type="checkbox" id="podman-select-all" onclick="podmanToggleAll(this)"></th>
      <th class="podman-sortable" data-sort="name" onclick="podmanSort('name')">Container <i class="fa fa-sort podman-sort-icon"></i></th>
      <th class="podman-sortable" data-sort="host" onclick="podmanSort('host')">Host <i class="fa fa-sort podman-sort-icon"></i></th>
      <th>State</th>
      <th>Image</th>
      <th>IP / Ports</th>
      <th class="podman-col-actions">Actions</th>
    </tr>
  </thead>
  <tbody id="podman_tbody">
    <tr><td colspan="7" style="text-align:center"><i class="fa fa-spinner fa-spin"></i> Loading...</td></tr>
  </tbody>
</table>

<div id="podman-log-dialog" style="display:none" title="Container Logs">
  <pre id="podman-log-content" class="podman-logs"></pre>
</div>

<div id="podman-update-dialog" style="display:none">
  <div class="podman-dialog-overlay" onclick="podmanCloseUpdateDialog()">
    <div class="podman-dialog-box" onclick="event.stopPropagation()">
      <div class="podman-dialog-title">Update Container</div>
      <div class="podman-dialog-body">
        Are you sure you want to update <code id="podman-update-name"></code>?<br>
        <br>
        This will pull the latest image and recreate the container.
      </div>
      <div class="podman-dialog-actions">
        <button class="podman-dialog-btn" onclick="podmanCloseUpdateDialog()">Cancel</button>
        <button class="podman-dialog-btn podman-dialog-confirm" id="podman-update-confirm" onclick="podmanConfirmUpdate()">Update</button>
      </div>
    </div>
  </div>
</div>

<script>
var podmanProxy = '/plugins/podman-manager/include/Events.php';
var podmanCsrfToken = '<?=$var["csrf_token"]?>';
function podmanApi(path) {
  return podmanProxy + '?action=api_proxy&csrf_token=' + encodeURIComponent(podmanCsrfToken) + '&path=' + encodeURIComponent('/api' + path);
}
var podmanRefreshMs = <?=$refreshInterval?>;
var podmanTimer = null;
var podmanData = null;
var podmanOpenDetail = null;
var podmanSortCol = 'name';
var podmanSortAsc = true;
var podmanUpdateStatus = {};  // { 'host/containerId': { update_available: bool, checking: bool } }
var podmanUpdateCheckTimer = null;
var podmanPendingUpdate = null;  // { host, containerId, name }

function podmanLoadList() {
  $.getJSON(podmanApi('/overview'), function(data) {
    podmanData = data;
    podmanRenderList(data);
    podmanRenderBadges(data);
    podmanRenderSummary(data);
    podmanScheduleUpdateChecks(data);
  }).fail(function() {
    $('#podman_tbody').html(
      '<tr><td colspan="7" style="text-align:center;color:#e04040">' +
      '<i class="fa fa-exclamation-triangle"></i> Backend unreachable. ' +
      'Is podman-manager running?</td></tr>'
    );
  }).always(function() {
    podmanTimer = setTimeout(podmanLoadList, podmanRefreshMs);
  });
}

function podmanScheduleUpdateChecks(data) {
  if (!data || !data.hosts) return;
  
  data.hosts.forEach(function(host) {
    if (host.status !== 'online' || !host.containers) return;
    
    host.containers.forEach(function(ct) {
      if (ct.state !== 'running') return;
      
      var key = host.name + '/' + ct.id;
      if (podmanUpdateStatus[key]) return;  // Already checked or checking
      
      podmanUpdateStatus[key] = { checking: true };
      $.getJSON(podmanApi('/hosts/' + host.name + '/containers/' + encodeURIComponent(ct.id) + '/update-check'),
        function(result) {
          podmanUpdateStatus[key] = {
            update_available: result.update_available || false,
            checking: false,
            local_digest: result.local_digest,
            remote_digest: result.remote_digest
          };
          podmanRenderList(podmanData);
        }
      ).fail(function() {
        podmanUpdateStatus[key] = { checking: false, error: true };
      });
    });
  });
}

function podmanRenderList(data) {
  var filter = $('#podman-filter').val().toLowerCase();
  var html = '';
  var checked = podmanGetSelected();

  if (!data || !data.hosts) {
    html = '<tr><td colspan="7" style="text-align:center">No data</td></tr>';
    $('#podman_tbody').html(html);
    return;
  }

  var allRows = [];

  data.hosts.forEach(function(host) {
    if (host.status !== 'online' || !host.containers) {
      allRows.push({offline: true, hostName: host.name, error: host.error});
      return;
    }

    host.containers.forEach(function(ct) {
      if (filter && ct.name.toLowerCase().indexOf(filter) === -1 &&
          ct.image.toLowerCase().indexOf(filter) === -1 &&
          host.name.toLowerCase().indexOf(filter) === -1) {
        return;
      }
      allRows.push({offline: false, hostName: host.name, ct: ct});
    });
  });

  allRows.sort(function(a, b) {
    if (a.offline && !b.offline) return 1;
    if (!a.offline && b.offline) return -1;
    if (a.offline && b.offline) return a.hostName.localeCompare(b.hostName);
    var valA, valB;
    if (podmanSortCol === 'host') { valA = a.hostName; valB = b.hostName; }
    else { valA = a.ct.name; valB = b.ct.name; }
    var cmp = valA.localeCompare(valB);
    return podmanSortAsc ? cmp : -cmp;
  });

  allRows.forEach(function(row) {
    if (row.offline) {
      html += '<tr class="podman-host-offline">' +
        '<td></td>' +
        '<td><i class="fa fa-server red-text"></i> ' + podmanEscapeHtml(row.hostName) + '</td>' +
        '<td colspan="5" class="red-text">' + podmanEscapeHtml(row.error || 'Offline') + '</td></tr>';
      return;
    }

    var ct = row.ct;
    var hostName = row.hostName;

    var stateIcon, stateClass;
    if (ct.state === 'running') {
      stateIcon = 'fa-play';
      stateClass = 'green-text';
    } else if (ct.state === 'exited' || ct.state === 'stopped') {
      stateIcon = 'fa-square';
      stateClass = 'red-text';
    } else {
      stateIcon = 'fa-circle';
      stateClass = 'orange-text';
    }

    var ports = '';
    if (ct.ports && ct.ports.length > 0) {
      ports = ct.ports.map(function(p) {
        var hostBind = (p.host_ip && p.host_ip !== '0.0.0.0') ? p.host_ip + ':' : '';
        return podmanEscapeHtml(hostBind + p.host_port + ':' + p.container_port + '/' + p.protocol);
      }).join('<br>');
    }

    var nets = '';
    if (ct.networks && ct.networks.length > 0) {
      nets = ct.networks.map(function(n) {
        return podmanEscapeHtml(n.ip ? n.name + ' (' + n.ip + ')' : n.name);
      }).join('<br>');
    }
    var ipPorts = [nets, ports].filter(Boolean).join('<br>');

    var shortImage = ct.image.replace(/^docker\.io\/library\//, '').replace(/^docker\.io\//, '');
    var rowKey = hostName + '/' + ct.id;
    var isChecked = checked.indexOf(rowKey) !== -1;
    var safeHostName = podmanEscapeHtml(hostName);
    var safeContainerID = podmanEscapeHtml(ct.id);
    var safeContainerName = podmanEscapeHtml(ct.name);
    var safeRowKey = podmanEscapeHtml(rowKey);
    var jsHostName = podmanJsArg(hostName);
    var jsContainerID = podmanJsArg(ct.id);
    var jsContainerName = podmanJsArg(ct.name);

    var managerBadge = '';
    if (ct.manager === 'quadlet') {
      managerBadge = ' <span class="podman-mgr-badge podman-mgr-quadlet" title="Managed by Quadlet (systemd)">Q</span>';
    } else if (ct.manager === 'compose') {
      managerBadge = ' <span class="podman-mgr-badge podman-mgr-compose" title="Managed by Compose">C</span>';
    }

    var updateKey = hostName + '/' + ct.id;
    var updateInfo = podmanUpdateStatus[updateKey];
    var updateBadge = '';
    if (updateInfo && updateInfo.update_available) {
      updateBadge = ' <span class="podman-update-badge" title="Update available"><i class="fa fa-arrow-up"></i> Update</span>';
    }

    var actions = '';
    if (ct.state === 'running') {
      actions = '<button class="podman-action-btn" onclick="podmanAction(\'' + jsHostName + '\',\'' + jsContainerID + '\',\'stop\'); event.stopPropagation(); return false;" title="Stop"><i class="fa fa-stop"></i></button>' +
        '<button class="podman-action-btn" onclick="podmanAction(\'' + jsHostName + '\',\'' + jsContainerID + '\',\'restart\'); event.stopPropagation(); return false;" title="Restart"><i class="fa fa-refresh"></i></button>';
    } else {
      actions = '<button class="podman-action-btn" onclick="podmanAction(\'' + jsHostName + '\',\'' + jsContainerID + '\',\'start\'); event.stopPropagation(); return false;" title="Start"><i class="fa fa-play"></i></button>';
    }
    actions += '<button class="podman-action-btn" onclick="podmanShowLogs(\'' + jsHostName + '\',\'' + jsContainerID + '\'); event.stopPropagation(); return false;" title="Logs"><i class="fa fa-file-text-o"></i></button>';
    
    if (updateInfo && updateInfo.update_available) {
      actions += '<button class="podman-action-btn podman-update-btn" onclick="podmanShowUpdateDialog(\'' + jsHostName + '\',\'' + jsContainerID + '\',\'' + jsContainerName + '\'); event.stopPropagation(); return false;" title="Update available"><i class="fa fa-arrow-up"></i></button>';
    }

    html += '<tr class="podman-ct-row" data-host="' + safeHostName + '" data-id="' + safeContainerID + '" ' +
      'data-name="' + safeContainerName + '" data-state="' + podmanEscapeHtml(ct.state) + '" ' +
      'onclick="podmanToggleDetail(\'' + jsHostName + '\',\'' + jsContainerName + '\',this)">' +
      '<td class="podman-col-check"><input type="checkbox" class="podman-row-check" data-key="' + safeRowKey + '"' + (isChecked ? ' checked' : '') + ' onclick="podmanUpdateBulk(); event.stopPropagation();"></td>' +
      '<td class="podman-ct-name">' +
        '<i class="fa ' + stateIcon + ' ' + stateClass + '"></i> ' +
        '<a href="#">' +
        safeContainerName + '</a>' + managerBadge + updateBadge + '</td>' +
      '<td>' + safeHostName + '</td>' +
      '<td><span class="' + stateClass + '">' + podmanEscapeHtml(ct.status) + '</span></td>' +
      '<td class="podman-image">' + podmanEscapeHtml(shortImage) + '</td>' +
      '<td class="podman-ports">' + ipPorts + '</td>' +
      '<td class="podman-col-actions">' + actions + '</td>' +
      '</tr>';

    if (podmanOpenDetail === rowKey) {
      html += '<tr class="podman-detail-row" data-detail-key="' + safeRowKey + '">' +
        '<td colspan="7"><div class="podman-inline-detail"><i class="fa fa-spinner fa-spin"></i> Loading...</div></td></tr>';
    }
  });

  if (html === '') {
    html = '<tr><td colspan="7" style="text-align:center">No containers found</td></tr>';
  }

  $('#podman_tbody').html(html);
  podmanUpdateBulk();
  podmanUpdateSortIcons();

  if (podmanOpenDetail) {
    podmanFetchDetail(podmanOpenDetail);
  }
}

function podmanToggleDetail(host, name, el) {
  var key = host + '/' + name;
  var $existingRow = $('tr[data-detail-key="' + key + '"]');

  if ($existingRow.length) {
    $existingRow.remove();
    podmanOpenDetail = null;
    return;
  }

  $('tr.podman-detail-row').remove();
  podmanOpenDetail = key;

  var $row = $(el).closest('tr');
  var detailHtml = '<tr class="podman-detail-row" data-detail-key="' + key + '">' +
    '<td colspan="7"><div class="podman-inline-detail"><i class="fa fa-spinner fa-spin"></i> Loading...</div></td></tr>';
  $row.after(detailHtml);

  podmanFetchDetail(key);
}

function podmanEscapeHtml(value) {
  return String(value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function podmanJsArg(value) {
  return podmanEscapeHtml(String(value)
    .replace(/\\/g, '\\\\')
    .replace(/'/g, "\\'")
    .replace(/\r/g, '\\r')
    .replace(/\n/g, '\\n'));
}

function podmanDetailRow(label, value) {
  var safeValue = value;
  if (safeValue === null || safeValue === undefined || safeValue === '') {
    safeValue = 'N/A';
  }
  return '<div class="podman-kv-row">' +
    '<div class="podman-kv-key">' + podmanEscapeHtml(label) + '</div>' +
    '<div class="podman-kv-value">' + podmanEscapeHtml(safeValue) + '</div>' +
    '</div>';
}

function podmanDetailRowHtml(label, htmlValue) {
  return '<div class="podman-kv-row podman-kv-row-block">' +
    '<div class="podman-kv-key">' + podmanEscapeHtml(label) + '</div>' +
    '<div class="podman-kv-value">' + htmlValue + '</div>' +
    '</div>';
}

function podmanRenderDetailList(items, emptyText) {
  if (!items || items.length === 0) {
    return '<div class="podman-empty">' + podmanEscapeHtml(emptyText || 'None') + '</div>';
  }

  var list = '<ul class="podman-detail-list">';
  items.forEach(function(item) {
    list += '<li>' + podmanEscapeHtml(item) + '</li>';
  });
  list += '</ul>';
  return list;
}

function podmanFetchDetail(key) {
  var parts = key.split('/');
  var host = parts[0];
  var name = parts.slice(1).join('/');

  $.getJSON(podmanApi('/hosts/' + host + '/containers/' + encodeURIComponent(name)), function(data) {
    var $detailRow = $('tr[data-detail-key="' + key + '"]');
    if (!$detailRow.length) return;

    var labelsHtml = '<div class="podman-empty">None</div>';
    if (data.labels && Object.keys(data.labels).length > 0) {
      labelsHtml = '<div class="podman-label-grid">';
      Object.keys(data.labels).sort().forEach(function(k) {
        labelsHtml += '<span class="podman-label">' + podmanEscapeHtml(k + '=' + data.labels[k]) + '</span>';
      });
      labelsHtml += '</div>';
    }

    var networkItems = [];
    if (data.networks && data.networks.length > 0) {
      data.networks.forEach(function(n) {
        networkItems.push((n.name || 'unknown') + ': ' + (n.ip || 'no IP') + ' (gw: ' + (n.gateway || 'none') + ')');
      });
    }

    var portItems = [];
    if (data.ports && data.ports.length > 0) {
      data.ports.forEach(function(p) {
        portItems.push((p.host_ip || '0.0.0.0') + ':' + p.host_port + ' -> ' + p.container_port + '/' + p.protocol);
      });
    }

    var mountItems = [];
    if (data.mounts && data.mounts.length > 0) {
      data.mounts.forEach(function(m) {
        var rw = m.rw ? 'rw' : 'ro';
        mountItems.push((m.source || 'unknown') + ' -> ' + (m.destination || 'unknown') + ' (' + (m.type || 'bind') + ', ' + rw + ')');
      });
    }

    var runtimeHtml = '';
    runtimeHtml += podmanDetailRow('Image', data.image);
    runtimeHtml += podmanDetailRow('State', (data.state || 'unknown') + ' (PID: ' + (data.pid || 'N/A') + ')');
    runtimeHtml += podmanDetailRow('Hostname', data.hostname || 'N/A');
    runtimeHtml += podmanDetailRow('Restart Policy', data.restart_policy || 'none');
    runtimeHtml += podmanDetailRow('Network Mode', data.network_mode || 'N/A');
    runtimeHtml += podmanDetailRowHtml('Labels', labelsHtml);

    var networkingHtml = '';
    networkingHtml += podmanDetailRowHtml('Networks', podmanRenderDetailList(networkItems, 'None'));
    networkingHtml += podmanDetailRowHtml('Ports', podmanRenderDetailList(portItems, 'None'));

    var volumesHtml = podmanRenderDetailList(mountItems, 'None');

    var html = '<div class="podman-inline-detail">';
    html += '<div class="podman-detail-head">';
    html += '<div class="podman-detail-title">' + podmanEscapeHtml(data.name || name) + '</div>';
    html += '<div class="podman-detail-close"><a href="#" onclick="podmanCloseDetail(); return false;"><i class="fa fa-times"></i> Close</a></div>';
    html += '</div>';
    html += '<div class="podman-detail-grid">';
    html += '<section class="podman-detail-card">';
    html += '<div class="podman-detail-section-title">Runtime</div>';
    html += runtimeHtml;
    html += '</section>';
    html += '<section class="podman-detail-card">';
    html += '<div class="podman-detail-section-title">Networking</div>';
    html += networkingHtml;
    html += '</section>';
    html += '<section class="podman-detail-card podman-detail-card-full">';
    html += '<div class="podman-detail-section-title">Volumes</div>';
    html += volumesHtml;
    html += '</section>';
    html += '</div>';
    html += '</div>';

    $detailRow.find('td').html(html);
  });
}

function podmanCloseDetail() {
  $('tr.podman-detail-row').remove();
  podmanOpenDetail = null;
}

function podmanRenderBadges(data) {
  var html = '';
  data.hosts.forEach(function(host) {
    var cls = host.status === 'online' ? 'green-text' : 'red-text';
    var icon = host.status === 'online' ? 'fa-check-circle' : 'fa-times-circle';
    var count = host.container_count || {};
    var label = host.name;
    if (host.status === 'online') {
      label += ' (' + (count.running || 0) + '/' + (count.total || 0) + ')';
    }
    html += '<span class="podman-badge ' + cls + '">' +
      '<i class="fa ' + icon + '"></i> ' + podmanEscapeHtml(label) + '</span> ';
  });
  $('#podman-host-badges').html(html);
}

function podmanRenderSummary(data) {
  var total = 0, running = 0;
  data.hosts.forEach(function(h) {
    if (h.container_count) {
      total += h.container_count.total;
      running += h.container_count.running;
    }
  });
  $('#podman-summary').text(running + ' / ' + total + ' running');
}

function podmanShortPath(p) {
  if (!p) return '';
  var parts = p.split('/');
  if (parts.length > 3) {
    return '.../' + parts.slice(-2).join('/');
  }
  return p;
}

function podmanAction(host, containerId, action) {
  var $row = $('.podman-ct-row[data-host="' + host + '"][data-name="' + containerId + '"]');
  var $icon = $row.find('.podman-ct-name i');
  var origClass = $icon.attr('class');
  $icon.attr('class', 'fa fa-refresh fa-spin');

  $.post(podmanApi('/hosts/' + host + '/containers/' + encodeURIComponent(containerId) + '/' + action),
    function(data) {
      if (data && !data.success) {
        if (typeof swal !== 'undefined') {
          swal('Error', data.error || 'Action failed', 'error');
        } else {
          alert('Error: ' + (data.error || 'Action failed'));
        }
      }
      setTimeout(podmanLoadList, 1000);
    }
  ).fail(function() {
    $icon.attr('class', origClass);
    alert('Failed to ' + action + ' container');
  });
}

function podmanGetSelected() {
  var keys = [];
  $('.podman-row-check:checked').each(function() {
    keys.push($(this).data('key'));
  });
  return keys;
}

function podmanUpdateBulk() {
  var count = $('.podman-row-check:checked').length;
  if (count > 0) {
    $('#podman-bulk-count').text(count + ' selected');
    $('#podman-bulk-bar').slideDown(150);
  } else {
    $('#podman-bulk-bar').slideUp(150);
  }
  var total = $('.podman-row-check').length;
  $('#podman-select-all').prop('checked', total > 0 && count === total);
}

function podmanToggleAll(el) {
  $('.podman-row-check').prop('checked', el.checked);
  podmanUpdateBulk();
}

function podmanClearSelection() {
  $('.podman-row-check').prop('checked', false);
  $('#podman-select-all').prop('checked', false);
  podmanUpdateBulk();
}

function podmanBulkAction(action) {
  var selected = podmanGetSelected();
  if (selected.length === 0) return;
  var msg = action.charAt(0).toUpperCase() + action.slice(1) + ' ' + selected.length + ' container(s)?';
  if (!confirm(msg)) return;

  var pending = selected.length;
  selected.forEach(function(key) {
    var parts = key.split('/');
    var host = parts[0];
    var name = parts.slice(1).join('/');
    $.post(podmanApi('/hosts/' + host + '/containers/' + encodeURIComponent(name) + '/' + action),
      function() {
        pending--;
        if (pending === 0) {
          podmanClearSelection();
          setTimeout(podmanLoadList, 1500);
        }
      }
    );
  });
}

function podmanShowLogs(host, containerId) {
  var tail = 200;
  $.getJSON(podmanApi('/hosts/' + host + '/containers/' + encodeURIComponent(containerId) + '/logs?tail=' + tail), function(data) {
    $('#podman-log-content').text(data.logs || 'No logs available');
    if ($.fn.dialog) {
      $('#podman-log-dialog').dialog({
        title: 'Logs: ' + containerId + ' (' + host + ')',
        modal: true, width: 900, height: 600,
        buttons: { Close: function() { $(this).dialog('close'); } }
      });
    } else {
      $('#podman-log-dialog').show();
    }
  });
}

function podmanSort(col) {
  if (podmanSortCol === col) {
    podmanSortAsc = !podmanSortAsc;
  } else {
    podmanSortCol = col;
    podmanSortAsc = true;
  }
  if (podmanData) podmanRenderList(podmanData);
}

function podmanUpdateSortIcons() {
  $('.podman-sortable .podman-sort-icon').removeClass('fa-sort-asc fa-sort-desc').addClass('fa-sort');
  var $active = $('.podman-sortable[data-sort="' + podmanSortCol + '"] .podman-sort-icon');
  $active.removeClass('fa-sort').addClass(podmanSortAsc ? 'fa-sort-asc' : 'fa-sort-desc');
}

$('#podman-filter').on('input', function() {
  if (podmanData) podmanRenderList(podmanData);
});

function podmanShowUpdateDialog(host, containerId, name) {
  podmanPendingUpdate = { host: host, containerId: containerId, name: name };
  $('#podman-update-name').text(name);
  $('#podman-update-dialog').show();
}

function podmanCloseUpdateDialog() {
  $('#podman-update-dialog').hide();
  podmanPendingUpdate = null;
}

function podmanConfirmUpdate() {
  if (!podmanPendingUpdate) return;
  
  var host = podmanPendingUpdate.host;
  var containerId = podmanPendingUpdate.containerId;
  var name = podmanPendingUpdate.name;
  
  podmanCloseUpdateDialog();
  
  var $row = $('.podman-ct-row[data-host="' + host + '"][data-name="' + containerId + '"]');
  var $icon = $row.find('.podman-ct-name i');
  var origClass = $icon.attr('class');
  $icon.attr('class', 'fa fa-refresh fa-spin');
  
  $.post(podmanApi('/hosts/' + host + '/containers/' + encodeURIComponent(containerId) + '/update'),
    function(data) {
      if (data && data.success) {
        delete podmanUpdateStatus[host + '/' + containerId];
        if (typeof swal !== 'undefined') {
          swal('Success', data.message || 'Container updated successfully', 'success');
        } else {
          alert(data.message || 'Container updated successfully');
        }
      } else {
        if (typeof swal !== 'undefined') {
          swal('Error', data.error || 'Update failed', 'error');
        } else {
          alert('Error: ' + (data.error || 'Update failed'));
        }
        $icon.attr('class', origClass);
      }
      setTimeout(podmanLoadList, 1500);
    }
  ).fail(function() {
    $icon.attr('class', origClass);
    alert('Failed to update container');
  });
}

$(function() {
  podmanLoadList();
});
</script>
