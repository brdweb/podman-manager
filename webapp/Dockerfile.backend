FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /podman-manager ./cmd/podman-manager

FROM alpine:3.21
RUN apk add --no-cache openssh-client
COPY --from=build /podman-manager /usr/local/bin/podman-manager
EXPOSE 18734
ENTRYPOINT ["/usr/local/bin/podman-manager"]
